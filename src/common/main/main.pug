include ../advantages/advantages.pug

mixin main(title, text, photo, adv1, adv2, adv3, adv4)
    section.main-section
        div.main-section__container._container
            div.main-section__top.main-block
                div.main-block__content
                    h1.main-block__title=title
                    div.main-block__text=text
                    div.main-block__buttons.buttons
                        a(href='#' class='button').buttons__telegram.button Спросить в Telegram
                        a(href="tel:+375293439439" class='button').buttons__phone.button +375 29 343 94 39
                div.main-block__media.media
                    img(src="src/images/triangle.svg").media__triangle 
                    div.media__rectangle 
                    img(src=photo).media__photo
            div.main-section__advantages
                +advantages(adv1)
                +advantages(adv2)
                +advantages(adv3)
                +advantages(adv4)