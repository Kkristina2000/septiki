<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мини-экскаватор</title>
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css")
    link(rel="stylesheet" href="src/scss/styles.css")
</head>
<body>
    div.wrapper
        include ../../common/header/header.pug
        main.main
            +main('Мини-экскаватор в аренду', 'Наличный и безналичный расчёт.', photoExcavator, 'Проверенную и подготовленную технику', 'Профессионального и опытного экскаваторщика', 'Своевременную доставку экскаваторы','Оперативное решение задач и поддержку')
            section.rings-section._container
                h1.stations-section__title.title наши мини-экскаваторы
                div.main-block__buttons.buttons
                    a(href='#' class='button').buttons__telegram.button Спросить в Telegram
                    a(href='tel:+375293439439' class='button').buttons__phone.button +375 29 343 94 39
                
            include ../../common/order/order.pug
            div.photos._container.photos-rings
                div.rings-block
                    img(src='src/images/excavator/excavator1.jpg')
                    img(src='src/images/excavator/excavator2.jpg')
                    img(src='src/images/excavator/excavator3.jpg')
                div.main-block__buttons.buttons
                    a(href='#' class='button').buttons__telegram.button Спросить в Telegram
                    a(href='tel:+375293439439' class='button').buttons__phone.button +375 29 343 94 39
            +comments(comments)
            +questions(questions)
            include ../../common/partners/partners.pug
            include ../../common/footer/footer.pug
