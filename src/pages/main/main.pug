-var advantages = [{amount:'10+', text: 'лет на рынкe'},{amount: '7 00+', text: 'проектов'},{amount: '5 70+', text: 'клиентов'}];

include ../../common/main/main.pug
include ../../common/advantage-company/advantage-company.pug
include ../../common/service/service.pug
doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible", content="IE=edge")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Главная
        link(rel="stylesheet" href="src/scss/styles.css")
    body
        div.wrapper
            include ../../common/header/header.pug
            .advantage-company-block
                .advantage-company-block__container._container
                    each advantage in advantages
                        +advantage-company(advantage)
            section.services-section 
                .services-section__container._container 
                    h1.services-section__title.title Наши услуги
                    div.services
                        each service in services 
                            +service(service)
                div.main-block__buttons.buttons
                    a(href='#' class='button').buttons__telegram.button Спросить в Telegram
                    a(href='tel:+375293439439' class='button').buttons__phone.button +375 29 343 94 39
            section.company-section
                .company-section__container._container
                    h1.company-section__title.title О компании
                        div 
                    a(href='#').buttons__phone.link Подробнее
            include ../../common/partners/partners.pug
            include ../../common/footer/footer.pug