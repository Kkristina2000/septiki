<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Кольца</title>
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css")
    link(rel="stylesheet" href="src/scss/styles.css")
</head>
<body>
    div.wrapper
        include ../../common/header/header.pug
        main.main
            +main('Септики из бетонных колец', 'Наличный и безналичный расчёт.', photoRings, 'оплата по факту выполненных работ', 'гарантия на монтаж 3 года', 'монтажники с опытом работы 5+ лет','Бесплатный выезд на замер')
            section.rings-section._container
                div.rings-section__container
                    h1.rings-section__title.title Варианты септиков из колец
                    div.rings-section__septiki
                        each septik in septiki 
                            +septik(septik)
                    div.rings-section__buttons.buttons
                        a(href='#' class='button').buttons__telegram.button Спросить в Telegram
                        a(href='tel:+375293439439' class='button').buttons__phone.button +375 29 343 94 39
            include ../../common/order/order.pug
            div.photos._container.photos-rings
                div.rings-block
                    img(src='src/images/rings/rings1.jpg')
                    img(src='src/images/rings/rings2.jpg')
                    img(src='src/images/rings/rings3.jpg')
                    img(src='src/images/rings/rings4.jpg')
                div.rings__buttons.buttons
                    a(href='#' class='button').buttons__telegram.button Спросить в Telegram
                    a(href='tel:+375293439439' class='button').buttons__phone.button +375 29 343 94 39
            +comments(comments)
            +questions(questions)
            include ../../common/partners/partners.pug
        include ../../common/footer/footer.pug
    script(src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js")
    script(src="src/js/comments.js")