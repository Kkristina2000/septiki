doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible", content="IE=edge")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Септики
        link(rel="stylesheet" href="src/scss/styles.css")
    body
        div.wrapper
        include ../../common/header/header.pug
        main.main
            +main('Хотите навсегда решить проблему с канализацией?', 'Канализация в дом под ключ с гарантией на все работы.', photoSeptiki, 'оплата по факту выполненных работ', 'гарантия на монтаж 3 года', 'монтажники с опытом работы 5+ лет','Бесплатный выезд на замер')
